# OAuth
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=your_kakao_redirect_uri
OAUTH2_FRONTEND_REDIRECT_URI=your_oauth2_frontend_redirect_uri

# JWT Token
JWT_SECRET=your_jwt_secret_key_at_least_256_bits

# AWS S3
AWS_REGION=your_aws_region_name
AWS_S3_UPLOAD_BUCKET_NAME=your_aws_s3_upload_bucket_name
AWS_S3_TTS_BUCKET_NAME=your_aws_s3_tts_bucket_name
AWS_S3_CDN_URL_PREFIX=your_aws_cdn_url_prefix
AWS_S3_KEY_PREFIX=your_aws_key_prefix
# 로컬에서 Instance Profile이 없을 때만 선택적으로 사용
AWS_PROFILE=your_aws_profile_name

# AWS Parameter Store
AWS_PARAMETER_STORE_ENABLED=your_parameter_store_enabled
AWS_PARAMETER_STORE_PATH=your_parameter_store_path

# SSM Parameter Store 로딩 트리거 (핵심)
SPRING_CONFIG_IMPORT=optional:aws-parameterstore:/qfeed/dev/be/

# AI Service URLs
AI_FEEDBACK_BASE_URL=your_ai_feedback_base_url
AI_STT_BASE_URL=your_ai_stt_base_url

# CORS
CORS_ALLOWED_ORIGIN=your_cors_allowed_origin

# DB
SPRING_DATASOURCE_URL=your_spring_datasource_url
SPRING_DATASOURCE_DRIVER=your_spring_datasource_driver
SPRING_DATASOURCE_USERNAME=your_spring_datasource_username
SPRING_DATASOURCE_PASSWORD=your_spring_datasource_password

# Abuse Guard
# per-user submissions per minute
ABUSE_GUARD_USER_PER_MINUTE=3

# per-user submissions per hour
ABUSE_GUARD_USER_PER_HOUR=30

# per-IP submissions per minute
ABUSE_GUARD_IP_PER_MINUTE=15

# cooldown (seconds) for re-submitting the same question
ABUSE_GUARD_QUESTION_COOLDOWN_SECONDS=60

# max consecutive submissions for the same question
ABUSE_GUARD_QUESTION_CONSECUTIVE_LIMIT=3

# max whitespace ratio (0.0~1.0)
ABUSE_GUARD_MAX_WHITESPACE_RATIO=0.4

# max repeated character length
ABUSE_GUARD_MAX_REPEAT_CHAR_COUNT=5

# min Korean/English ratio (0.0~1.0)
ABUSE_GUARD_MIN_KOREAN_ENGLISH_RATIO=0.5

# similarity block threshold (0.0~1.0)
ABUSE_GUARD_SIMILARITY_THRESHOLD=0.9

# min score to provide feedback
ABUSE_GUARD_MIN_SCORE_FOR_FEEDBACK=60

# min score to accept 저장
ABUSE_GUARD_MIN_SCORE_FOR_ACCEPT=30

# daily hard submission limit
ABUSE_GUARD_DAILY_QUOTA_LIMIT=15

# daily soft feedback limit
ABUSE_GUARD_SOFT_QUOTA_LIMIT=10

# enable rate limit guard
ABUSE_GUARD_RATE_LIMIT_ENABLED=true

# enable content quality guard
ABUSE_GUARD_CONTENT_QUALITY_ENABLED=true

# enable duplicate/similarity guard
ABUSE_GUARD_DUPLICATE_ENABLED=true

# enable quality score guard
ABUSE_GUARD_QUALITY_SCORE_ENABLED=true

# enable daily quota guard
ABUSE_GUARD_QUOTA_ENABLED=true

INTERVIEW_SESSION_REAL_MAX_TURN=9
